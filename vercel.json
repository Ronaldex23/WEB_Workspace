{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "TODOapp/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist/TODOapp/browser" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/index.js" },
    { "source": "/(.*)", "destination": "/TODOapp/dist/TODOapp/browser/index.html" }
  ]
}